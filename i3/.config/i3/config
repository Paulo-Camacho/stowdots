# ------------ "maps/keymaps" ------------------
set $mod Mod4
exec --no-startup-id setxkbmap -option ctrl:swapcaps
font pango: RobotoMono Nerd Font 20
# ------------- xinput ------------
# exec --no-startup-id xinput set-prop 11 "libinput Accel Speed" 0.4

# -------------- system applications/programs -----------------------
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork


# ----------------------- using feh to display background wallpaper -----
exec_always feh --bg-fill ~/shared/inspo/hans.jpg

# ---------- using i3lock to have a lockscreen ---------------------------
bindsym $mod+p exec i3lock
# bindsym $mod+d exec --no-startup-id dmenu_run -fn 'RobotoMono Nerd Font-25'

bindsym $mod+d exec "dmenu_run -nf '#BBBBBB' -nb '#222222' -sb '#a188f7' -sf '#EEEEEE' -fn 'RobotoMono Nerd Font-12' -p 'dmenu prompt &gt;'"
# ----------------------- using feh to display background wallpaper -----
exec_always feh --bg-fill ~/shared/inspo/hans.jpg

# ----------- warm screen --------------------------
exec --no-startup-id redshift -O 4000

# ------------ emacs ---------------
# exec --no-startup-id emacs --daemon
# bindsym $mod+y exec emacsclient -c -n
# bindsym $mod+y exec --no-startup-id emacs

# ---------- terminal ------------
bindsym $mod+Return exec kitty
exec --no-startup-id flameshot
bindsym Print exec --no-startup-id flameshot gui -c
bindsym $mod+e exec --no-startup-id env GDK_SCALE=1 GDK_DPI_SCALE=1 nemo
bindsym $mod+w exec --no-startup-id env GDK_SCALE=1 GDK_DPI_SCALE=1 brave-browser 

# --------------- using blueman for bluetooth --------
exec --no-startup-id blueman-applet
exec --no-startup-id nm-applet

# notice how we are using XF86
# ------------- adjusting brightness using brightnessctl --------------
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +10%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 10%-

# ----------- using playerctl to control video player ----------------
bindsym XF86AudioPrev exec --no-startup-id playerctl previous
bindsym XF86AudioPlay exec --no-startup-id playerctl play-pause
bindsym XF86AudioNext exec --no-startup-id playerctl next
# ------------- adjusting volumejusing pactl --------------------------
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status


# Use Mouse+$mod to drag floating windows to their wanted position
# I want to be apply to resize when floating and holding a mod instead
# move tiling windows via drag & drop by left-clicking into the title bar,
# or left-clicking anywhere into the window while holding the floating modifier.
tiling_drag modifier titlebar

# ------------- eye-candy ------------
gaps inner 10
gaps outer 2
# this settings makes it so that a single window fits the entire screen
# smart_gaps on
smart_borders on
for_window [class=".*"] border none

# ---------------- movement/keybinds ----------------------- 
# kill focused window
bindsym $mod+Shift+q kill
# change focus
bindsym $mod+h focus left
bindsym $mod+l focus right
bindsym $mod+k focus up
bindsym $mod+j focus down
# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
# split in horizontal orientation
bindsym $mod+s split h
# split in vertical orientation
bindsym $mod+a split v
# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle
# toggle tiling / floating
# hold the leader key to move a window while inside this mode to move said window
floating_modifier $mod
bindsym $mod+Shift+space floating toggle

### workspaces ###
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# reload the configuration file
bindsym $mod+Shift+c reload
# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r restart
# exit i3 (logs you out of your X session)
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'Paulo, do you really want to exit i3? ' -B 'Yes, exit i3' 'i3-msg exit'"

# resize window
mode "resize"
{
        bindsym h resize shrink width 10 px or 10 ppt
        bindsym k resize grow height 10 px or 10 ppt
        bindsym j resize shrink height 10 px or 10 ppt
        bindsym l resize grow width 10 px or 10 ppt

        # back to normal: Enter or Escape or $mod+r
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

bar
{
  status_command i3status
    font pango:RobotoMono Nerd Font 9
    position top
    colors {
      background #000000
        statusline #FFFFFF
        separator  #666666

        focused_workspace  #A188F7 #A188F7 #FFFFFF
        active_workspace   #333333 #222222 #FFFFFF
        inactive_workspace #333333 #222222 #888888
        urgent_workspace   #2F343A #900000 #FFFFFF
        binding_mode       #2F343A #900000 #FFFFFF
    }
}
