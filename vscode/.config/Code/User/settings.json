{
    "window.titleBarStyle": "custom",
    "window.menuBarVisibility": "classic",
    "window.customTitleBarVisibility": "never",
    "window.openFilesInNewWindow": "on",

    "workbench.colorTheme": "GitHub Light",
    "workbench.sideBar.location": "left",
    "workbench.secondarySideBar.defaultVisibility": "visible",
    "workbench.editor.enablePreview": false,
    "workbench.startupEditor": "none",

    "editor.fontSize": 14,
    "editor.fontVariations": false,
    "editor.fontLigatures": true,
    "editor.minimap.enabled": false,
    "editor.suggest.insertMode": "replace",
    "editor.bracketPairColorization.independentColorPoolPerBracketType": true,

    "files.insertFinalNewline": true,
    "files.autoSave": "afterDelay",
    "explorer.confirmDelete": false,

    "security.workspace.trust.untrustedFiles": "open",
    "update.showReleaseNotes": false,
    "redhat.telemetry.enabled": false,
    "git.openRepositoryInParentFolders": "never",

    "vim.useSystemClipboard": true,
    "vim.overrideCopy": true,
    "vim.highlightedyank.enable": true,
    "vim.highlightedyank.color": "yellow",
    "vim.leader": "<Space>",
    "vim.hlsearch": true,
    "vim.handleKeys": {
        "<C-p>": false
    },

    "terminal.integrated.enableMultiLinePasteWarning": "never",

    "cmake.showOptionsMovedNotification": false,
    "cmake.configureOnOpen": true,
    "cmake.pinnedCommands": [
        "workbench.action.tasks.configureTaskRunner",
        "workbench.action.tasks.runTask"
    ],
    "makefile.configureOnOpen": true,

    "C_Cpp.default.cppStandard": "c++20",

    "python.analysis.typeCheckingMode": "standard",
    "python.defaultInterpreterPath": "/Library/Frameworks/Python.framework/Versions/3.14/bin/python3.14",

    "github.copilot.nextEditSuggestions.enabled": true,
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false,
        "cpp": false,
        "python": false
    },

    "markdown-preview-enhanced.enablePreviewZenMode": false,
    "markdown-preview-enhanced.codeBlockTheme": "auto.css",
    "markdown-preview-enhanced.revealjsTheme": "none.css",
    "markdown-preview-enhanced.previewTheme": "github-light.css",

    "launch": {},

    "[json]": {},
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    }
}